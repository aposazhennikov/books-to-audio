{
  "1": {
    "class_type": "FB_Qwen3TTSCustomVoice",
    "_comment": "Main TTS synthesis node. {{TEXT}}, {{SPEAKER}}, {{INSTRUCT}} are replaced per chunk.",
    "inputs": {
      "text": "{{TEXT}}",
      "speaker": "{{SPEAKER}}",
      "model_choice": "1.7B",
      "device": "auto",
      "precision": "bf16",
      "language": "{{LANGUAGE}}",
      "instruct": "{{INSTRUCT}}",
      "max_new_tokens": 2048,
      "top_p": 0.65,
      "top_k": 12,
      "temperature": 0.55,
      "repetition_penalty": 1.08,
      "attention": "auto",
      "unload_model_after_generate": true
    }
  },
  "2": {
    "class_type": "SaveAudio",
    "_comment": "Saves audio output. {{OUTPUT_FILENAME}} becomes the filename prefix.",
    "inputs": {
      "audio": ["1", 0],
      "filename_prefix": "{{OUTPUT_FILENAME}}"
    }
  }
}
